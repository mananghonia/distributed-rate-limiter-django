# Copy to .env and adjust. Values here are the defaults used if unset.
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=1

# Where the gateway forwards allowed requests. Point this at your real backend.
# Defaults to the bundled demo upstream app running on the same server.
UPSTREAM_BASE_URL=http://127.0.0.1:8000/demo-upstream

# Redis connection. If Redis is unreachable and RATELIMIT_USE_FAKEREDIS=1,
# an in-process fakeredis is used instead (dev/test only).
REDIS_URL=redis://127.0.0.1:6379/0
RATELIMIT_USE_FAKEREDIS=1

# Which algorithm the limiter uses: fixed_window | sliding_window | token_bucket
RATELIMIT_ALGORITHM=sliding_window

# fail_open = allow traffic if Redis is down (available, unprotected)
# fail_closed = reject traffic if Redis is down (protected, unavailable)
RATELIMIT_FAILURE_MODE=fail_open
